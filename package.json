{
  "name": "@pedrofariasx/qwenproxy",
  "version": "1.3.0",
  "description": "Local OpenAI-compatible proxy API that routes requests to Qwen (chat.qwen.ai) via Playwright browser automation.",
  "main": "index.js",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "start:bun": "bun run src/index.bun.ts",
    "start:firefox": "npx tsx src/index.ts --browser=firefox",
    "start:chrome": "npx tsx src/index.ts --browser=chrome",
    "start:edge": "npx tsx src/index.ts --browser=edge",
    "login": "npx tsx src/login.ts",
    "login:firefox": "npx tsx src/login.ts --browser=firefox",
    "login:chrome": "npx tsx src/login.ts --browser=chrome",
    "login:edge": "npx tsx src/login.ts --browser=edge",
    "test": "tsx --test src/**/*.test.ts",
    "test:new": "tsx --test src/tests/semantic-cache.test.ts src/tests/token-estimation.test.ts src/tests/model-router.test.ts src/tests/ab-testing.test.ts src/tests/speculative.test.ts src/tests/worker-pool.test.ts src/tests/multi-tenant.test.ts src/tests/opentelemetry.test.ts src/tests/edge-deployment.test.ts src/tests/header-cache.test.ts src/tests/context-summarizer.test.ts src/tests/runtime.test.ts src/tests/account-lock.test.ts src/tests/multi-agent-integration.test.ts",
    "test:lock": "tsx --test src/tests/account-lock.test.ts",
    "test:multiagent": "tsx --test src/tests/multi-agent-integration.test.ts",
    "test:legacy": "tsx --test src/**/*.test.ts",
    "bench": "tsx src/tests/benchmark.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Pedro Farias",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "ajv": "^8.20.0",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^12.10.0",
    "cacheable-lookup": "^7.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.21",
    "js-tiktoken": "^1.0.21",
    "playwright": "^1.60.0",
    "tsx": "^4.22.3",
    "undici": "^8.4.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/ajv": "^0.0.5",
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/uuid": "^11.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "bin": {
    "qwenproxy": "./bin/qwenproxy.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/**/*",
    "bin/**/*"
  ],
  "type": "module"
}
