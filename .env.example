# ============================================================
# QwenProxy Configuration
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0
API_KEY=your-api-key-here

# Browser
HEADLESS=true
BROWSER=chromium
USER_DATA_DIR=./qwen_profiles

# Timeouts (ms)
NAVIGATION_TIMEOUT=30000
PAGE_TIMEOUT=15000
HTTP_TIMEOUT=10000
CHAT_TIMEOUT=120000

# Cache
CACHE_TTL=3600
RESPONSE_TTL=1800

# Metrics & Watchdog
METRICS_INTERVAL=10000
WATCHDOG_INTERVAL=5000
WATCHDOG_FAILURES=3
RAM_WARNING=80
RAM_CRITICAL=95
WS_WARNING=50
WS_CRITICAL=100

# Qwen API
QWEN_BASE_URL=https://chat.qwen.ai

# ============================================================
# NEW MODULES (Roadmap 2026)
# ============================================================

# Semantic Cache (SimHash-based fuzzy matching)
# Reduces latency by ~60% on cache hits, 15-30% hit rate typical
SEMANTIC_CACHE_ENABLED=true

# Adaptive Token Estimation (BPE-like, replaces heuristic)
# Better accuracy (±10%) vs old length/divisor method
TOKEN_ESTIMATION_MODE=adaptive

# Model Router (automatic model selection based on prompt features)
# Routes: code→coder, multimodal→vl, long→max, simple→27b
MODEL_ROUTER_ENABLED=true
MODEL_ROUTER_RESPECT_CLIENT=true

# Context Summarization (auto-summarize when >80% context window)
# Saves ~70% tokens on long conversations
SUMMARIZER_ENABLED=true
SUMMARIZER_THRESHOLD=0.8
SUMMARIZER_MODEL=qwen3.6-27b

# Speculative Parallel Requests (fast no-thinking + slow thinking in bg)
# -40% perceived latency, logs divergences for router training
SPECULATIVE_ENABLED=false
SPECULATIVE_THRESHOLD=0.7

# Worker Threads for SSE Parsing (offload from main thread)
# P99 latency -50% under load, 3-5x more concurrent requests
WORKER_POOL_ENABLED=true
WORKER_POOL_SIZE=2

# OpenTelemetry (distributed tracing + structured logging)
# 10% sampling default, console exporter
OPENTELEMETRY_ENABLED=false
OPENTELEMETRY_SAMPLING_RATE=0.1
OPENTELEMETRY_EXPORTER=console

# Multi-Tenant (isolation via X-Tenant-Key header)
# Rate limits, model restrictions, usage accounting
MULTI_TENANT_ENABLED=false

# ============================================================
# MULTI-AGENT PARALLEL EXECUTION (S1 + S2)
# ============================================================
#
# Headers suportados pelo /v1/chat/completions:
#
#   X-Account-Id: <accountId>
#     Pin request to a specific Qwen account. Each subagent in a
#     multi-agent setup should use its OWN account via this header.
#     Configured in Hermes via custom_providers.headers.
#     If the pinned account is busy, request waits up to 30s then
#     returns 429 (never auto-rotates to another account).
#
#   X-Agent-Id: <agentId>
#     Identifier for observability. Shows up in logs and lock info.
#     Use e.g. "orchestrator", "subagent-1", "worker-xyz".
#
# Example Hermes config for 5 parallel subagents:
#
#   custom_providers:
#     qwen-agent-1:
#       base_url: http://localhost:3000/v1
#       api_key: ***
#       headers:
#         X-Account-Id: acc-geen-01
#         X-Agent-Id: subagent-1
#     qwen-agent-2:
#       base_url: http://localhost:3000/v1
#       api_key: ***
#       headers:
#         X-Account-Id: acc-geen-02
#         X-Agent-Id: subagent-2
#     ... (one per account)
#
# LOCK_TIMEOUT_MS=30000
#   How long a PINNED request (with X-Account-Id) waits for the account
#   to become free before returning HTTP 429. Rotating requests (no
#   X-Account-Id) always fail-fast and try the next account.
#
# With N distinct accounts pinned this way, you get N truly parallel
# subagents with zero "chat in progress" errors.
# ============================================================

# Edge Deployment (for Cloudflare Workers / Deno Deploy)
# Run `tsx src/core/edge-deployment.ts` to generate configs
EDGE_ENABLED=false
EDGE_PROVIDER=cloudflare
